# Dashboard configuration — copy to `.env` (gitignored) to override defaults.

# Base URL of the AuraSense hub API.
VITE_HUB_URL=http://localhost:8000

# Pairing code the dashboard uses to obtain a bearer token from the hub.
# Must match the hub's AURASENSE_PAIRING_CODE.
VITE_PAIRING_CODE=aurasense-dev
