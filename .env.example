# AuraSense hub configuration — copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.

# --- Database ---
# NOTE: docker-compose maps TimescaleDB to host port 5434 (not 5432), so when
# running the hub services on the host, use 5434 here.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/aurasense

# --- MQTT broker ---
MQTT_BROKER=localhost
MQTT_PORT=1883

# --- Auth (stage F2) ---
# Strong random string used to sign pairing JWTs. Generate e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AURASENSE_JWT_SECRET=change-me-to-a-long-random-string
# Out-of-band code a client presents to POST /api/v1/pair to obtain a token.
AURASENSE_PAIRING_CODE=aurasense-dev
# Issued-token lifetime in hours.
AURASENSE_TOKEN_TTL_HOURS=24
# Comma-separated CORS allow-list for the dashboard / app origins.
AURASENSE_ALLOWED_ORIGINS=http://localhost:3000

# --- Inference ---
# IANA timezone for hour-of-day logic (e.g. America/New_York). Empty = host local.
AURASENSE_TZ=
